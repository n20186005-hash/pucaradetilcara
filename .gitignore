# ─── 依赖 ───
node_modules/

# ─── 构建产物（均不需上传）───
dist/            # Astro 构建输出
out/             # 旧 Next.js 静态导出（含往期站点遗留域名，禁止上传）
.astro/          # Astro 缓存目录

# ─── 历史脚本与临时文件（往期站点遗留，禁止上传）───
fix-quotes*.js
fix-quotes*.cjs
fix-quotes*.py
fix_quotes*.py
fix_quotes*.js
rename-*.js
rename-*.cjs
update-*.js
update-*.cjs
scripts/rename-gallery.cjs   # 一次性图片重命名脚本，已完成任务
scripts/verify.cjs           # 一次性校验脚本，已完成任务
build.ps1                    # 构建脚本，本地使用

# ─── 日志 ───
*.log
build.log

# ─── 类型产物 ───
*.tsbuildinfo

# ─── 环境变量 / 密钥（切勿上传）───
.env
.env.local
.env*.local

# ─── 操作系统 / 编辑器临时文件 ───
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
